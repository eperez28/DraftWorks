{
  "name": "draftworks-mvp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "npm --prefix frontend run dev",
    "dev:api": "uvicorn backend.app.main:app --reload --host 0.0.0.0 --port 8000",
    "build:web": "npm --prefix frontend run build",
    "lint:web": "npm --prefix frontend run lint"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
